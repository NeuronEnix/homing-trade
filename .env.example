# homing-trade — environment template.
#
# HOW TO USE:
#   1. Copy this file to `.env`           ->   cp .env.example .env
#   2. Fill in your real values in `.env`
#   3. `.env` is gitignored, so your real keys NEVER get committed or pushed.
#
# You ONLY need these if you deliberately arm live trading. Paper trading,
# backtesting, and the daemon need NOTHING here.

# CoinDCX API credentials. Create them at: CoinDCX -> Profile -> API Dashboard.
# Keep them secret. Never paste them into code, chat, or a public place.
COINDCX_API_KEY=
COINDCX_API_SECRET=

# --- AI traders (optional) — Claude reads the 1m + 15m charts and decides entries ---
# Direction/timing only; size/leverage/risk stay with the engine. Two INDEPENDENT brains,
# each toggled + paced on its own. Enable either, both, or neither — if both are on they
# trade side by side (separate wallets) so you can compare them on the leaderboard.
#
# Brain 1 — Claude Code CLI (NO API key; rides your Claude Code subscription):
# AI_CLAUDE_CODE_IS_ENABLED=true
# AI_CLAUDE_CODE_POLL_IN_SEC=3600
#
# Brain 2 — Anthropic API (needs ANTHROPIC_API_KEY; cheaper/faster per call):
# AI_ANTHROPIC_IS_ENABLED=false
# AI_ANTHROPIC_POLL_IN_SEC=900
# ANTHROPIC_API_KEY=sk-ant-...
#
# HT_LLM_MODEL=claude-opus-4-8    # model both brains use (claude-haiku-4-5 to cut cost)
#
# More brains — any provider via AI_<NAME>_* flags (backend: cli|api|openai|mistral|llama).
# Each spins up its own wallet as strategy llm_<name>. SECURITY GATE: only the two built-ins
# above are approved by default; any OTHER <NAME> must be listed in AI_PROVIDERS_WHITELIST
# (comma-separated, case-insensitive) or it is ignored — so a stray flag can't mint a brain.
# AI_PROVIDERS_WHITELIST=grok,mixtral
# AI_GROK_IS_ENABLED=true
# AI_GROK_BACKEND=openai          # uses the OpenAI-compatible adapter
# AI_GROK_POLL_IN_SEC=900
# AI_GROK_MODEL=grok-2
# AI_MIXTRAL_BACKEND=mistral      # MISTRAL_API_KEY for api providers; LLAMA_BASE_URL for llama

# --- External research signals (Phase 6) — all optional, all degrade-safe ---
# Fear & Greed, Binance funding/OI, and CoinDCX microstructure are free + keyless (default ON;
# mute with FNG_IS_ENABLED / DERIVS_IS_ENABLED / COINDCX_SIGNAL_IS_ENABLED = false).
# CoinGecko reference price works keyless too; a FREE Demo key just lifts the rate limit:
# COINGECKO_DEMO_KEY=CG-xxxxxxxx      # https://www.coingecko.com/en/developers/dashboard
# PRICE_REF_IS_ENABLED=true

# --- Autonomous loops + portfolio gates (built; default OFF — opt in here) ---
# The reflect->learn loop: retrospects over closed trades on a slow cadence and FILES human-gated
# playbook proposals (never applies anything). Uses the local `claude` CLI (no API key/billing).
# REFLECTION_IS_ENABLED=true
# REFLECTION_MODEL=sonnet          # defaults to HT_LLM_MODEL; sonnet is the cheaper choice
# REFLECTION_POLL_IN_SEC=3600      # how often it runs   REFLECTION_MIN_TRADES=5
# Regime gate (Phase 7 #3): scales a strategy's position size down when its style mismatches the
# current regime (trend follower in chop / reverter in a trend) — only ever REDUCES exposure.
# REGIME_FILTER_IS_ENABLED=true
# REGIME_UNFAVORED_WEIGHT=0.5            # size x this on a style/regime mismatch
# REGIME_COMMITTEE_THRESHOLD_SCALE=1.5  # committee needs stronger consensus when not trending
# Performance-weighted capital allocator (Phase 4) + committee consensus bar:
# ALLOCATOR_IS_ENABLED=true   ALLOCATOR_LOOKBACK=20   COMMITTEE_THRESHOLD=0.2
# Candidate-strategy research scan -> human-gated strategy_toggle proposals (daily, consults an LLM):
# RESEARCH_IS_ENABLED=true
# Continuous walk-forward backtest job -> SQLite -> dashboard (daily, no network, stored candles):
# CONTINUOUS_BACKTEST_IS_ENABLED=true
# Discord inbound approvals: poll #comms for approve/reject replies (needs the bot token below):
# COMMS_INBOUND_IS_ENABLED=true   COMMS_POLL_IN_SEC=30

# --- Trading / risk controls (futures, INR margin) ---
# All optional; sensible defaults live in code. Override here without touching code.
# The bot trades at HT_LEVERAGE_MAX (no single leverage knob needed).
# HT_LEVERAGE_MIN=1
# HT_LEVERAGE_MAX=15
# HT_MAX_TRADE_PER_DAY=0       # 0 = no cap; else max INR notional opened per day
# HT_MAX_DAILY_LOSS=0          # 0 = off; KILL SWITCH: halt once the day's loss hits this (INR)
# HT_TRADING_ENABLED=true      # set to false to STOP trading immediately

# --- Discord alerts (recommended) ---
# Get pinged on every paper trade + daemon start/stop/crash. To turn it on:
#   1. In your Discord server: Server Settings -> Integrations -> Webhooks -> New Webhook
#      -> pick a channel -> Copy Webhook URL.
#   2. Uncomment the two lines below (paste your URL), then run: python -m homing_trade.daemon
# HT_ALERT_MODE=discord
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdefg...

# --- Telegram alerts (alternative) ---
#   @BotFather -> /newbot -> token; get your chat id (see README). Then:
# HT_ALERT_MODE=telegram
# TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather
# TELEGRAM_CHAT_ID=123456789

# --- Agent comms channel (homing_trade/comms.py) ---
# Outbound (webhook): the agent posts actionable items / progress here during long tasks.
# COMMS_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Inbound (read your replies) needs a BOT TOKEN — webhooks are write-only. Create a bot at
# discord.com/developers (enable Message Content Intent, add it to your server with Read
# Message History), then set:
# DISCORD_BOT_TOKEN=
# COMMS_CHANNEL_ID=        # right-click the #comms channel -> Copy Channel ID (Dev Mode on)

# --- #paper-trade narration feed (Phase 11 #1; narrate-only, default OFF + degrade-safe) ---
# When enabled AND a webhook is set, every paper trade is narrated to a dedicated feed with the
# message contract: what / why / risk / decision_id / level. It NEVER asks for approval — paper just
# runs. Create a webhook on a #paper-trade channel and set both:
# PAPER_TRADE_IS_ENABLED=true
# PAPER_TRADE_WEBHOOK_URL=https://discord.com/api/webhooks/...
