# homing-trade — environment template.
#
# HOW TO USE:
#   1. Copy this file to `.env`           ->   cp .env.example .env
#   2. Fill in your real values in `.env`
#   3. `.env` is gitignored, so your real keys NEVER get committed or pushed.
#
# You ONLY need these if you deliberately arm live trading. Paper trading,
# backtesting, and the daemon need NOTHING here.

# CoinDCX API credentials. Create them at: CoinDCX -> Profile -> API Dashboard.
# Keep them secret. Never paste them into code, chat, or a public place.
COINDCX_API_KEY=
COINDCX_API_SECRET=

# --- LLM trader (optional) — Claude reads the 1m + 15m charts and decides entries ---
# Direction/timing only; size/leverage/risk stay with the engine. Two backends:
#   cli (default): shells out to your local `claude` CLI — NO API key, rides your Claude
#                  Code subscription. Heavier/slower per call (~Claude Code system context).
#   api          : Anthropic SDK — needs ANTHROPIC_API_KEY; leaner/cheaper/faster per call.
# Enable by adding llm_trader to HT_SKILLS:
# HT_SKILLS=ma_trend,rsi_revert,grid,macd,bollinger,donchian,llm_trader
# HT_LLM_BACKEND=cli              # cli (no key) | api
# HT_LLM_MODEL=claude-opus-4-8    # or claude-haiku-4-5 to cut cost
# ANTHROPIC_API_KEY=sk-ant-...    # ONLY needed for HT_LLM_BACKEND=api

# --- Trading / risk controls (futures, INR margin) ---
# All optional; sensible defaults live in code. Override here without touching code.
# The bot trades at HT_LEVERAGE_MAX (no single leverage knob needed).
# HT_LEVERAGE_MIN=1
# HT_LEVERAGE_MAX=15
# HT_MAX_TRADE_PER_DAY=0       # 0 = no cap; else max INR notional opened per day
# HT_MAX_DAILY_LOSS=0          # 0 = off; KILL SWITCH: halt once the day's loss hits this (INR)
# HT_TRADING_ENABLED=true      # set to false to STOP trading immediately

# --- Discord alerts (recommended) ---
# Get pinged on every paper trade + daemon start/stop/crash. To turn it on:
#   1. In your Discord server: Server Settings -> Integrations -> Webhooks -> New Webhook
#      -> pick a channel -> Copy Webhook URL.
#   2. Uncomment the two lines below (paste your URL), then run: python -m homing_trade.daemon
# HT_ALERT_MODE=discord
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdefg...

# --- Telegram alerts (alternative) ---
#   @BotFather -> /newbot -> token; get your chat id (see README). Then:
# HT_ALERT_MODE=telegram
# TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather
# TELEGRAM_CHAT_ID=123456789
